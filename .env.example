# Supabase (lưu session + lịch sử phỏng vấn)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Dashboard mới: Publishable key — hoặc dùng Anon key (cùng vai trò client)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional — dev fallback cho API proxy (user vẫn nhập key trên web)
DEEPGRAM_API_KEY=
DEEPSEEK_API_KEY=
# Optional — chỉ khi chọn provider Google trong Settings
GOOGLE_TRANSLATE_API_KEY=
